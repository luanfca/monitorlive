{
  "entities": {
    "MonitoredPlayer": {
      "title": "MonitoredPlayer",
      "description": "A player being monitored by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "number", "description": "Internal ID." },
        "sofaId": { "type": "number", "description": "SofaScore Player ID." },
        "name": { "type": "string", "description": "Player name." },
        "eventId": { "type": "number", "description": "SofaScore Event ID." },
        "alerts": {
          "type": "object",
          "properties": {
            "tackles": { "type": "boolean" },
            "fouls": { "type": "boolean" },
            "foulsDrawn": { "type": "boolean" },
            "shots": { "type": "boolean" },
            "shotsOn": { "type": "boolean" },
            "yellow": { "type": "boolean" },
            "subOut": { "type": "boolean" },
            "interceptions": { "type": "boolean" },
            "duelsWon": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "sofaId", "name", "eventId", "alerts"]
    }
  },
  "firestore": {
    "/users/{userId}/monitoredPlayers/{playerId}": {
      "schema": { "$ref": "MonitoredPlayer" },
      "description": "Players monitored by a specific user."
    }
  }
}
