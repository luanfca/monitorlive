{
  "name": "live-match-pro",
  "private": true,
  "version": "1.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/luanfca/SofaTracker.git"
  },
  "type": "module",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/server.js --external:express --external:firebase-admin --external:vite --external:got-scraping",
    "lint": "tsc --noEmit",
    "build:mobile": "vite build && npx cap sync",
    "preview": "vite preview",
    "cap:add": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open android"
  },
  "overrides": {
    "yallist": "^4.0.0"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.1.0",
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.1.0",
    "@capacitor/local-notifications": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.2",
    "@capgo/capacitor-updater": "^8.43.8",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "got-scraping": "^4.2.1",
    "lucide-react": "^0.563.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.1.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "esbuild": "^0.27.4",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
