rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users/{userId}/monitoredPlayers
    // Document ID: {playerId}
    // Fields:
    //   - id: number (required)
    //   - sofaId: number (required)
    //   - name: string (required)
    //   - eventId: number (required)
    //   - alerts: map (required)
    //   - createdAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
       return request.auth != null;
    }

    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidMonitoredPlayer(data) {
      return data.keys().hasAll(['id', 'sofaId', 'name', 'eventId', 'alerts']) &&
             data.id is number &&
             data.sofaId is number &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.eventId is number &&
             data.alerts is map;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId}/monitoredPlayers/{playerId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidMonitoredPlayer(request.resource.data);
      allow update: if isOwner(userId) && isValidMonitoredPlayer(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /notifications/{notificationId} {
      // Notifications are generally read-only for users
      allow read: if true;
      // Only system/server should write notifications
      allow write: if false;
    }
  }
}
